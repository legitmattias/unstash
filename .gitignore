# =====================================================
# Secrets — NEVER commit anything in secrets/
# =====================================================
# Use secrets/* instead of secrets/ so git still descends into the
# directory and the negations below actually apply.
secrets/*
!secrets/.gitkeep
!secrets/README.md
.env
.env.*
!.env.example

# =====================================================
# Python
# =====================================================
__pycache__/
*.py[cod]
*$py.class
*.so
.Python
build/
develop-eggs/
dist/
downloads/
eggs/
.eggs/
lib/
lib64/
parts/
sdist/
var/
wheels/
share/python-wheels/
